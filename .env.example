# Copy to .env and fill in real values. Never commit .env.

PORT=3000
NODE_ENV=development

# SQL Server connection
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=arcade
DB_USER=arcade_app
DB_PASSWORD=change-me

# Random 32+ byte secret used to sign session cookies, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me
