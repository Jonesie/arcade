# Copy to .env and fill in real values. Never commit .env.

PORT=3000
NODE_ENV=development

# SQL Server connection
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=arcade
DB_USER=arcade_app
DB_PASSWORD=change-me

# Random 32+ byte secret used to sign session cookies, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me

# Outbound email for account verification codes. Leave SMTP_HOST blank to
# run with no email delivery at all (verification codes are only logged
# server-side, never actually sent) — everything else still works.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=noreply@arcade.jonesie.net.nz
SMTP_PASSWORD=
MAIL_FROM_NAME="The Dog House"
MAIL_FROM_ADDRESS=noreply@arcade.jonesie.net.nz

# Used to build links in emails (e.g. the "verify your email" button).
PUBLIC_BASE_URL=http://localhost:5173

# Comma-separated email addresses granted admin access once verified on
# an account, e.g. ADMIN_EMAILS=you@example.com,other-admin@example.com
ADMIN_EMAILS=
